{
  "name": "hammoc",
  "version": "1.1.2",
  "description": "Web-based IDE for managing Claude Code sessions, projects, and workflows",
  "type": "module",
  "license": "AGPL-3.0-only",
  "author": {
    "name": "starsh2001",
    "url": "https://github.com/starsh2001"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/starsh2001/hammoc.git"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ide",
    "ai",
    "session-manager",
    "developer-tools"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "hammoc": "./bin/hammoc.js"
  },
  "files": [
    "bin/",
    "scripts/",
    "packages/server/dist/",
    "packages/server/package.json",
    "packages/client/dist/",
    "packages/shared/dist/",
    "packages/shared/package.json"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w packages/server\" \"npm run dev -w packages/client\"",
    "build": "npm run build -w packages/shared && npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "start": "npm run start -w packages/server",
    "prod": "npm run build && npm run start",
    "lint": "eslint \"packages/*/src/**/*.{ts,tsx}\"",
    "format": "prettier --write packages/*/src",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "postinstall": "node scripts/postinstall.cjs",
    "prepublishOnly": "npm run build",
    "bmad:refresh": "bmad-method install -f -i codex",
    "bmad:list": "bmad-method list:agents",
    "bmad:validate": "bmad-method validate"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.34",
    "bcrypt": "^6.0.0",
    "cookie-session": "^2.1.1",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "express": "^4.21.0",
    "i18next": "^24.2.3",
    "js-yaml": "^4.1.1",
    "multer": "^2.1.1",
    "node-pty": "^1.0.0",
    "simple-git": "^3.27.0",
    "socket.io": "^4.8.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/web-push": "^3.6.4",
    "concurrently": "^8.2.2",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "@types/react": "^18.3.0",
    "@types/express": "4.17.25",
    "@types/express-serve-static-core": "4.19.8"
  }
}
