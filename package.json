{
  "name": "bmad-studio",
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w packages/server\" \"npm run dev -w packages/client\"",
    "build": "npm run build -w packages/shared && npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "start": "npm run start -w packages/server",
    "prod": "npm run build && npm run start",
    "lint": "eslint \"packages/*/src/**/*.{ts,tsx}\"",
    "format": "prettier --write packages/*/src",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "bmad:refresh": "bmad-method install -f -i codex",
    "bmad:list": "bmad-method list:agents",
    "bmad:validate": "bmad-method validate"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/multer": "^2.0.0",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.18"
  },
  "bin": {
    "bmad-studio": "./bin/bmad-studio.js"
  }
}
