{
  "name": "@hammoc/server",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --import tsx/esm --watch src/dev.ts",
    "build": "tsc && node -e \"require('fs').cpSync('src/locales','dist/locales',{recursive:true})\"",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude '**/**.integration.test.ts'",
    "test:watch": "vitest --exclude '**/**.integration.test.ts'",
    "test:coverage": "vitest run --coverage --exclude '**/**.integration.test.ts'",
    "test:integration": "vitest run src/services/__tests__/chatService.integration.test.ts",
    "test:all": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.34",
    "@hammoc/shared": "*",
    "bcrypt": "^6.0.0",
    "cookie-session": "^2.1.1",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "i18next": "^24.2.3",
    "js-yaml": "^4.1.1",
    "multer": "^2.1.1",
    "node-pty": "^1.0.0",
    "simple-git": "^3.27.0",
    "socket.io": "^4.8.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-session": "^2.0.49",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/express-serve-static-core": "^4.19.8",
    "@types/js-yaml": "^4.0.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^2.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
