# Server Configuration
PORT=3000
HOST=localhost

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Chat Settings
# Timeout for chat responses in milliseconds (default: 300000 = 5 minutes)
CHAT_TIMEOUT_MS=300000

# Engine Mode Toggle (Epic 33, optional — default OFF)
# Exposes the SDK/CLI conversation-engine selector in settings (global + per-project).
# Billing-confirmation gate: keep OFF until the billing-split confirmation (Jun 15) is GO;
# then set to true so the operator can expose the toggle. While OFF the effective engine is
# forced to 'sdk' even if a 'cli' selection was persisted.
# ENGINE_MODE_TOGGLE_ENABLED=true

# Logging
# Log level: ERROR | WARN | INFO | DEBUG | VERBOSE (default: DEBUG in dev, INFO in prod)
# LOG_LEVEL=DEBUG

# Session Configuration (managed by cookie-session)
# SESSION_SECRET is auto-generated if not provided

# Telegram Notifications (optional)
# Sends alerts when background streaming needs user input or completes
# Get bot token from @BotFather, chat ID from @userinfobot
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=123456789
