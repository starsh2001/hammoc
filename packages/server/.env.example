# Server Configuration
PORT=3000
HOST=localhost

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Chat Settings
# Timeout for chat responses in milliseconds (default: 300000 = 5 minutes)
CHAT_TIMEOUT_MS=300000

# Logging
# Log level: ERROR | WARN | INFO | DEBUG | VERBOSE (default: DEBUG in dev, INFO in prod)
# LOG_LEVEL=DEBUG

# CLI-mode screen dump (debug only)
# The CLI (subscription-pool) engine runs claude in a windowless virtual terminal,
# so its screen is normally invisible. Set this to capture the raw terminal output
# (ANSI intact) of every CLI turn to a file you can replay afterwards:
#   cat <file>  /  Get-Content -Raw <file> | Write-Host   → reconstructs the screen
# Values: unset/false/0 = off · 1/true = dump to ~/.hammoc/debug/cli-pty/ · <dir> = dump there
# HAMMOC_CLI_PTY_DUMP=1

# Session Configuration (managed by cookie-session)
# SESSION_SECRET is auto-generated if not provided

# Telegram Notifications (optional)
# Sends alerts when background streaming needs user input or completes
# Get bot token from @BotFather, chat ID from @userinfobot
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=123456789
